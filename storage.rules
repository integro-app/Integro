rules_version = '2';

/*
 * Caminho obrigatório para novos anexos:
 * /tenants/{clientePlataformaId}/{categoria}/{arquivo}
 *
 * Requer custom claims clientePlataformaId e role, emitidas por backend.
 */
service firebase.storage {
  match /b/{bucket}/o {
    function autenticado() {
      return request.auth != null;
    }

    function masterGlobal() {
      return autenticado() && request.auth.token.role == "master_global";
    }

    function mesmoTenant(tenantId) {
      return autenticado() &&
        request.auth.token.clientePlataformaId != null &&
        request.auth.token.clientePlataformaId == tenantId;
    }

    match /tenants/{tenantId}/{allPaths=**} {
      allow read: if masterGlobal() || mesmoTenant(tenantId);
      allow write: if (masterGlobal() || mesmoTenant(tenantId))
        && request.resource.size < 10 * 1024 * 1024;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
